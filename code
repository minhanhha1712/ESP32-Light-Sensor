// ================== UTILS ==================
String safeFloat(float v, uint8_t digits = 2) {
  if (isnan(v)) return "NA";
  return String(v, (unsigned int)digits);
}

String luxString(float v, uint8_t digits = 2) {
  if (isnan(v) || v < 0) return "NA";
  return String(v, (unsigned int)digits);
}

String htmlEscape(String s) {
  s.replace("&", "&amp;");
  s.replace("<", "&lt;");
  s.replace(">", "&gt;");
  s.replace("\"", "&quot;");
  return s;
}

// ================== OLED MESSAGE ==================
void oledMessage(String line1, String line2 = "", String line3 = "", String line4 = "") {
  if (!oledOK) return;

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);

  display.setCursor(0, 0);
  display.println(line1);

  display.setCursor(0, 16);
  display.println(line2);

  display.setCursor(0, 32);
  display.println(line3);

  display.setCursor(0, 48);
  display.println(line4);

  display.display();
}

// ================== SD SEQUENCE ==================
unsigned long readSequenceFromSD() {
  if (!sdOK) return 0;
  if (!SD.exists(SEQ_FILE)) return 0;

  File f = SD.open(SEQ_FILE, FILE_READ);
  if (!f) return 0;

  String s = f.readStringUntil('\n');
  f.close();

  s.trim();
  return s.toInt();
}

void saveSequenceToSD(unsigned long seq) {
  if (!sdOK) return;

  if (SD.exists(SEQ_FILE)) {
    SD.remove(SEQ_FILE);
  }

  File f = SD.open(SEQ_FILE, FILE_WRITE);
  if (!f) {
    Serial.println("Khong ghi duoc seq.txt");
    return;
  }

  f.println(seq);
  f.close();
}

void createCSVHeaderIfNeeded() {
  if (!sdOK) return;
  if (SD.exists(DATA_FILE)) return;

  File f = SD.open(DATA_FILE, FILE_WRITE);
  if (!f) {
    Serial.println("Khong tao duoc data.csv");
