  f.println("No,Uptime_ms,Temp_C,Humidity_percent,Pressure_hPa,Lux,Full,IR,Visible,PM1_0,PM2_5,PM10,PMS_Status");
  f.close();

  Serial.println("Da tao data.csv");
}

// ================== TSL2591 CONFIG ==================
void configureTSL2591() {
  tsl.setGain(TSL2591_GAIN_LOW);                 // Best for outdoor bright light
  tsl.setTiming(TSL2591_INTEGRATIONTIME_100MS);
}

// ================== PMS7003 READ ==================
bool readPMS7003(PMSData &data, uint16_t timeoutMs = 300) {
  uint8_t buffer[32];
  uint32_t startTime = millis();

  data.valid = false;
  data.pm1_0 = 0;
  data.pm2_5 = 0;
  data.pm10 = 0;

  while (millis() - startTime < timeoutMs) {
    if (PMS.available() >= 32) {
      if (PMS.peek() != 0x42) {
        PMS.read();
        continue;
      }

      PMS.readBytes(buffer, 32);

      if (buffer[0] != 0x42 || buffer[1] != 0x4D) {
        continue;
      }

      uint16_t frameLen = (buffer[2] << 8) | buffer[3];
      if (frameLen != 28) {
        continue;
      }

      uint16_t sum = 0;
      for (int i = 0; i < 30; i++) {
        sum += buffer[i];
      }

      uint16_t checksum = (buffer[30] << 8) | buffer[31];

      if (sum != checksum) {
        Serial.println("PMS checksum sai");
        continue;
      }

      // Atmospheric environment values
      data.pm1_0 = (buffer[10] << 8) | buffer[11];
      data.pm2_5 = (buffer[12] << 8) | buffer[13];
      data.pm10  = (buffer[14] << 8) | buffer[15];

      data.valid = true;
      return true;
    }
  }

  return false;
}

// ================== SENSOR READ ==================
void readSensorsRealtime() {
  if (bmeOK) {
    curTemp = bme.readTemperature();
    curHum  = bme.readHumidity();
    curPres = bme.readPressure() / 100.0F;
  }

  if (tslOK) {
    uint32_t lum = tsl.getFullLuminosity();

    curIR = lum >> 16;
    curFull = lum & 0xFFFF;

    if (curFull >= curIR) {
      curVisible = curFull - curIR;
    } else {
      curVisible = 0;
    }

    curLux = tsl.calculateLux(curFull, curIR);

    if (isnan(curLux) || curLux < 0) {
      curLux = -1;
    }
  }

  PMSData tempPMS;
  if (readPMS7003(tempPMS, 300)) {
    curPMS = tempPMS;
  }

  lastSensorReadMs = millis();
}

// ================== OLED REALTIME SCROLL ==================
void showOLEDRealtime() {
  if (!oledOK) return;

  String lines[OLED_TOTAL_LINES];

  lines[0]  = "IP: " + WiFi.softAPIP().toString();
  lines[1]  = "SSID: " + String(AP_SSID);
  lines[2]  = "T: " + (isnan(curTemp) ? String("NA") : String(curTemp, 1)) + " C";
  lines[3]  = "H: " + (isnan(curHum) ? String("NA") : String(curHum, 0)) + " %";
  lines[4]  = "P: " + (isnan(curPres) ? String("NA") : String(curPres, 0)) + " hPa";
  lines[5]  = "Lux: " + ((curLux < 0 || isnan(curLux)) ? String("NA") : String(curLux, 0));
  lines[6]  = "Full: " + String(curFull);
  lines[7]  = "IR: " + String(curIR);
  lines[8]  = "Visible: " + String(curVisible);

  if (curPMS.valid) {
    lines[9]  = "PM1.0: " + String(curPMS.pm1_0);
    lines[10] = "PM2.5: " + String(curPMS.pm2_5);
    lines[11] = "PM10 : " + String(curPMS.pm10);
  } else {
    lines[9]  = "PM1.0: waiting";
    lines[10] = "PM2.5: waiting";
    lines[11] = "PM10 : waiting";
  }

  lines[12] = "SD: " + String(sdOK ? "OK" : "FAIL");
  lines[13] = "Saved No: " + String(lastSavedNo);

  unsigned long passed = millis() - lastLogTime;
  unsigned long remain = 0;
  if (passed < LOG_INTERVAL) {
    remain = (LOG_INTERVAL - passed) / 1000;
  }
  lines[14] = "Next save: " + String(remain) + "s";

  // Cuon tung dong sau moi OLED_SCROLL_INTERVAL
  if (millis() - lastOledScrollTime >= OLED_SCROLL_INTERVAL) {
    lastOledScrollTime = millis();
    oledScrollLine++;

    if (oledScrollLine > OLED_TOTAL_LINES - OLED_VISIBLE_LINES) {
      oledScrollLine = 0;
    }
  }

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);

  for (int i = 0; i < OLED_VISIBLE_LINES; i++) {
    int lineIndex = oledScrollLine + i;
    display.setCursor(0, i * 10);
    display.print(lines[lineIndex]);
  }

  display.display();
}

