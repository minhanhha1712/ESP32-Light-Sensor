}

void handleDownload() {
  if (!sdOK || !SD.exists(DATA_FILE)) {
    server.send(404, "text/plain; charset=utf-8", "data.csv not found or SD not ready");
    return;
  }

  File f = SD.open(DATA_FILE, FILE_READ);
  if (!f) {
    server.send(500, "text/plain; charset=utf-8", "Cannot open data.csv");
    return;
  }

  server.streamFile(f, "text/csv");
  f.close();
}

void handleNotFound() {
  server.send(404, "text/plain; charset=utf-8", "404 Not Found");
}

void setupWebServer() {
  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/last", handleLastRows);
  server.on("/download", handleDownload);
  server.onNotFound(handleNotFound);
  server.begin();

  Serial.println("Web server started.");
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("Khoi dong ESP32 Air Light Web Logger...");

  curPMS.valid = false;

  // ---------- I2C ----------
  Wire.begin(I2C_SDA, I2C_SCL);
  delay(100);

  // ---------- OLED ----------
  if (display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    oledOK = true;
    Serial.println("OLED OK dia chi 0x3C");
  } else if (display.begin(SSD1306_SWITCHCAPVCC, 0x3D)) {
    oledOK = true;
    Serial.println("OLED OK dia chi 0x3D");
  } else {
    oledOK = false;
    Serial.println("Khong tim thay OLED");
  }

  if (oledOK) {
    oledMessage("System starting", "ESP32 Web Logger", "Starting AP...", "");
    delay(1000);
  }

  // ---------- WiFi AP ----------
  WiFi.mode(WIFI_AP);
  bool apOK = WiFi.softAP(AP_SSID, AP_PASS);

  if (apOK) {
    Serial.println("WiFi AP started.");
    Serial.print("SSID: ");
    Serial.println(AP_SSID);
    Serial.print("PASS: ");
    Serial.println(AP_PASS);
    Serial.print("IP: ");
    Serial.println(WiFi.softAPIP());
  } else {
    Serial.println("WiFi AP start FAILED.");
  }

  // ---------- PMS7003 ----------
  PMS.begin(9600, SERIAL_8N1, PMS_RX, PMS_TX);
  Serial.println("PMS7003 UART2 OK");

  // ---------- BME280 ----------
  if (bme.begin(0x76)) {
    bmeOK = true;
    Serial.println("BME280 OK 0x76");
  } else if (bme.begin(0x77)) {
    bmeOK = true;
    Serial.println("BME280 OK 0x77");
  } else {
    bmeOK = false;
    Serial.println("BME280 FAIL");
  }

  // ---------- TSL2591 ----------
  if (tsl.begin()) {
    tslOK = true;
    Serial.println("TSL2591 OK");
    configureTSL2591();
  } else {
    tslOK = false;
    Serial.println("TSL2591 FAIL");
  }

  // ---------- MicroSD ----------
  SPI.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);

  if (SD.begin(SD_CS)) {
    sdOK = true;
    Serial.println("MicroSD OK");
  } else {
    sdOK = false;
    Serial.println("MicroSD FAIL");
  }

  if (sdOK) {
    createCSVHeaderIfNeeded();
    sampleIndex = readSequenceFromSD();
    lastSavedNo = sampleIndex;
  }

  // ---------- Web ----------
  setupWebServer();

  if (oledOK) {
    oledMessage(
      "AP: ESP32_AIR_LIGHT",
      "Pass: 12345678",
      "IP: " + WiFi.softAPIP().toString(),
      sdOK ? "SD: OK" : "SD: FAIL"
    );
    delay(3000);
  }

  // First read + first save
  readSensorsRealtime();
  showOLEDRealtime();
  printSerialRealtime();

  logDataToSD();

  lastDisplayTime = millis();
  lastLogTime = millis();
}

// ================== LOOP ==================
void loop() {
  server.handleClient();

  unsigned long now = millis();

  // OLED + Serial + sensor update
  if (now - lastDisplayTime >= DISPLAY_INTERVAL) {
    lastDisplayTime = now;

    readSensorsRealtime();
    showOLEDRealtime();
    printSerialRealtime();
  }

  // SD save every 5 minutes
  if (now - lastLogTime >= LOG_INTERVAL) {
    lastLogTime = now;
    logDataToSD();
  }
}
