// ================== SD LOG ==================
void logDataToSD() {
  if (!sdOK) {
    Serial.println("SD FAIL, khong ghi duoc");
    return;
  }

  sampleIndex++;

  File f = SD.open(DATA_FILE, FILE_APPEND);
  if (!f) {
    Serial.println("Khong mo duoc data.csv");
    return;
  }

  f.print(sampleIndex);
  f.print(",");

  f.print(millis());
  f.print(",");

  if (isnan(curTemp)) f.print("NA");
  else f.print(curTemp, 2);
  f.print(",");

  if (isnan(curHum)) f.print("NA");
  else f.print(curHum, 2);
  f.print(",");

  if (isnan(curPres)) f.print("NA");
  else f.print(curPres, 2);
  f.print(",");

  if (curLux < 0 || isnan(curLux)) f.print("NA");
  else f.print(curLux, 2);
  f.print(",");

  f.print(curFull);
  f.print(",");

  f.print(curIR);
  f.print(",");

  f.print(curVisible);
  f.print(",");

  if (curPMS.valid) {
    f.print(curPMS.pm1_0);
    f.print(",");
    f.print(curPMS.pm2_5);
    f.print(",");
    f.print(curPMS.pm10);
    f.print(",");
    f.println("OK");
  } else {
    f.println("NA,NA,NA,FAIL");
  }

  f.close();

  saveSequenceToSD(sampleIndex);
  lastSavedNo = sampleIndex;

  Serial.print("Da luu mau so ");
  Serial.println(sampleIndex);
}

// ================== JSON API ==================
String buildJsonData() {
  String json = "{";

  json += "\"uptime_ms\":" + String(millis()) + ",";
  json += "\"ip\":\"" + WiFi.softAPIP().toString() + "\",";
  json += "\"ssid\":\"" + String(AP_SSID) + "\",";
  json += "\"bme_ok\":" + String(bmeOK ? "true" : "false") + ",";
  json += "\"tsl_ok\":" + String(tslOK ? "true" : "false") + ",";
  json += "\"sd_ok\":" + String(sdOK ? "true" : "false") + ",";
  json += "\"oled_ok\":" + String(oledOK ? "true" : "false") + ",";
  json += "\"pms_ok\":" + String(curPMS.valid ? "true" : "false") + ",";

  json += "\"temp\":\"" + safeFloat(curTemp, 2) + "\",";
  json += "\"hum\":\"" + safeFloat(curHum, 2) + "\",";
  json += "\"pres\":\"" + safeFloat(curPres, 2) + "\",";
  json += "\"lux\":\"" + luxString(curLux, 2) + "\",";

  json += "\"full\":" + String(curFull) + ",";
  json += "\"ir\":" + String(curIR) + ",";
  json += "\"visible\":" + String(curVisible) + ",";

  if (curPMS.valid) {
    json += "\"pm1_0\":" + String(curPMS.pm1_0) + ",";
    json += "\"pm2_5\":" + String(curPMS.pm2_5) + ",";
    json += "\"pm10\":" + String(curPMS.pm10) + ",";
  } else {
    json += "\"pm1_0\":\"NA\",";
    json += "\"pm2_5\":\"NA\",";
    json += "\"pm10\":\"NA\",";
  }

  json += "\"last_saved_no\":" + String(lastSavedNo) + ",";
  json += "\"next_save_in_s\":" + String((LOG_INTERVAL - (millis() - lastLogTime)) / 1000);

  json += "}";

  return json;
}

// ================== READ LAST CSV ROWS ==================
String getLastCSVRows(uint16_t maxLines = 30) {
  if (!sdOK || !SD.exists(DATA_FILE)) {
    return "SD not ready or data.csv not found";
  }

  File f = SD.open(DATA_FILE, FILE_READ);
  if (!f) {
    return "Cannot open data.csv";
  }

  const size_t MAX_CHARS = 5000;
  String content = "";

  while (f.available()) {
    char c = f.read();
    content += c;

    if (content.length() > MAX_CHARS) {
      content.remove(0, content.length() - MAX_CHARS);
    }
  }

  f.close();

  // Keep only last maxLines lines
  int lines = 0;
  int cutIndex = 0;

  for (int i = content.length() - 1; i >= 0; i--) {
    if (content[i] == '\n') {
      lines++;
      if (lines > maxLines) {
        cutIndex = i + 1;
        break;
      }
    }
  }

  if (cutIndex > 0) {
    content = content.substring(cutIndex);
  }

  return content;
}

